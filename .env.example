# Local development only (`npm run dev`). Copy to `.env` and adjust as needed.
#
# In the Docker image these are NOT used -- the built image resolves URLs at
# CONTAINER START from `environment:` in docker-compose.yml via
# docker-entrypoint.sh (see /public/config.js and src/lib/config.ts for the
# full resolution order). These VITE_* vars only apply when you're running
# the Vite dev server directly on your host.

VITE_API_BASE_URL="http://localhost:8000/api/v1"
VITE_RAG_LAB_URL="http://localhost:8002"
VITE_PROMPTOPS_LAB_URL="http://localhost:8003"
VITE_SCHEMA_LAB_URL="http://localhost:8004"
VITE_REVIEW_LAB_URL="http://localhost:8005"
VITE_MEMORY_LAB_URL="http://localhost:8006"
