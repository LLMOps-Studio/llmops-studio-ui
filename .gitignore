# macOS host and committed, which broke Docker builds (npm/cli#4828 --
# platform-locked optional native binaries like @tailwindcss/oxide-*).
# Both `npm install` locally and inside Docker now resolve dependencies
# fresh for whatever platform they're actually running on.
